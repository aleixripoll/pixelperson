---
interface Props {
  baseUrl: string;
  currentPage: number;
  totalPages: number;
}

const { baseUrl, currentPage, totalPages } = Astro.props;

function hrefForPage(n: number): string {
  if (n <= 1) return baseUrl;
  return `${baseUrl}page/${n}/`;
}

const pageNumbers = Array.from({ length: totalPages }, (_, i) => i + 1);
---

{
  totalPages > 1 && (
    <nav class="pagination" aria-label="Pagination">
      {currentPage > 1 && (
        <a href={hrefForPage(currentPage - 1)} class="pagination-link pagination-prev">
          ← Prev
        </a>
      )}

      <div class="pagination-jump">
        <label for={`pagination-page-${currentPage}`} class="pagination-jump-label">
          Page
        </label>
        <div class="pagination-select-wrap">
          <select
            id={`pagination-page-${currentPage}`}
            class="pagination-select"
            data-pagination-select
          >
            {pageNumbers.map((n) => (
              <option value={hrefForPage(n)} selected={n === currentPage}>
                {n}
              </option>
            ))}
          </select>
        </div>
        <span class="pagination-jump-of">of {totalPages}</span>
      </div>

      {currentPage < totalPages && (
        <a href={hrefForPage(currentPage + 1)} class="pagination-link pagination-next">
          Next →
        </a>
      )}
    </nav>
  )
}

<script>
  document.querySelectorAll("[data-pagination-select]").forEach((el) => {
    el.addEventListener("change", (e) => {
      const target = e.target as HTMLSelectElement;
      const href = target.value;
      if (href) window.location.href = href;
    });
  });
</script>
