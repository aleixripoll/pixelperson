---
interface Props {
  baseUrl: string;
  years: number[];
  currentYear: number | null; // null = "All"
}

const { baseUrl, years, currentYear } = Astro.props;
---
<div class="year-filter mb-8 flex flex-wrap items-center gap-2">
  <span class="text-sm text-[var(--color-muted)] mr-1">Year:</span>
  <select
    class="year-filter-select rounded-md px-3 py-1.5 text-sm font-medium bg-transparent border border-[var(--color-border)] text-[var(--color-text)] cursor-pointer"
    aria-label="Filter by year"
    data-year-filter
  >
    <option value={baseUrl} {...(currentYear === null && { selected: true })}>All</option>
    {years.map((y) => (
      <option value={`${baseUrl}year/${y}/`} {...(currentYear === y && { selected: true })}>
        {y}
      </option>
    ))}
  </select>
</div>
<script>
  document.querySelectorAll('[data-year-filter]').forEach((select) => {
    select.addEventListener('change', (e) => {
      const target = e.target as HTMLSelectElement;
      if (target.value) window.location.href = target.value;
    });
  });
</script>
