---
import "../styles/global.css";

interface Props {
  title?: string;
  description?: string;
}

const { title = "pixelperson", description = "A simple masonry blog" } = Astro.props;
---
<!DOCTYPE html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="description" content={description} />
    <title>{title}</title>
    <link rel="icon" type="image/svg+xml" href={`${import.meta.env.BASE_URL}favicon.svg`} />
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link href="https://fonts.googleapis.com/css2?family=Source+Serif+4:ital,opsz,wght@0,8..60,400;0,8..60,500;0,8..60,600;0,8..60,700;1,8..60,400;1,8..60,500&display=swap" rel="stylesheet" />
    <script is:inline>
      (function() {
        const stored = localStorage.getItem('theme');
        if (stored === 'dark' || stored === 'light') {
          document.documentElement.classList.add(stored);
        }
      })();
    </script>
  </head>
  <body>
    <header class="border-b border-[var(--color-border)] bg-[var(--color-bg)]" data-base-url={import.meta.env.BASE_URL}>
      <div class="mx-auto max-w-6xl px-4 py-5 sm:px-6 flex items-center justify-between gap-4">
        <a
          href={import.meta.env.BASE_URL}
          class="site-title flex items-center gap-2.5 text-xl font-semibold text-[var(--color-text)] no-underline shrink-0 group"
        >
          <span
            class="site-title-icon text-[var(--color-muted)] transition-colors duration-200 group-hover:text-[var(--color-accent)]"
            aria-hidden="true"
          >
            <svg
              width="22"
              height="22"
              viewBox="0 0 24 24"
              fill="none"
              stroke="currentColor"
              stroke-width="1.5"
              stroke-linecap="round"
              stroke-linejoin="round"
            >
              <path d="M2 3h6a4 4 0 0 1 4 4v14a4 4 0 0 0-4-4H2z" />
              <path d="M22 3h-6a4 4 0 0 0-4 4v14a4 4 0 0 1 4-4h6z" />
            </svg>
          </span>
          <span class="transition-colors duration-200 group-hover:text-[var(--color-accent)]">pixelperson</span>
        </a>
        <div class="header-search flex-1 max-w-xs min-w-0 flex justify-center">
          <div class="header-search-inner relative w-full">
            <div class="flex items-center gap-2 rounded-md border border-[var(--color-border)] bg-[var(--color-bg)] focus-within:ring-2 focus-within:ring-[var(--color-accent)] focus-within:border-transparent">
              <span class="header-search-icon pl-3 text-[var(--color-muted)] shrink-0" aria-hidden="true">
                <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><circle cx="11" cy="11" r="8"/><path d="m21 21-4.35-4.35"/></svg>
              </span>
              <input
                type="search"
                id="post-search"
                class="header-search-input flex-1 min-w-0 border-0 bg-transparent py-1.5 pr-3 text-sm text-[var(--color-text)] placeholder-[var(--color-muted)] focus:outline-none focus:ring-0"
                placeholder="Search posts…"
                autocomplete="off"
                aria-label="Search posts"
              />
            </div>
            <div id="search-results" class="header-search-results absolute top-full left-0 right-0 z-50 mt-1 hidden rounded-md border border-[var(--color-border)] bg-[var(--color-bg)] shadow-lg max-h-80 overflow-y-auto" role="listbox" aria-label="Search results"></div>
          </div>
        </div>
        <button
          type="button"
          id="theme-toggle"
          class="theme-toggle rounded-lg p-2 text-[var(--color-text)] hover:bg-[var(--color-border)] transition-colors"
          aria-label="Toggle light/dark theme"
        >
          <span class="theme-icon theme-icon-sun" aria-hidden="true" title="Switch to dark mode">
            <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="4"/><path d="M12 2v2M12 20v2M4.93 4.93l1.41 1.41M17.66 17.66l1.41 1.41M2 12h2M20 12h2M6.34 17.66l-1.41 1.41M19.07 4.93l-1.41 1.41"/></svg>
          </span>
          <span class="theme-icon theme-icon-moon theme-icon-hidden" aria-hidden="true" title="Switch to light mode">
            <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><path d="M21 12.79A9 9 0 1 1 11.21 3 7 7 0 0 0 21 12.79z"/></svg>
          </span>
        </button>
      </div>
    </header>
    <script is:inline>
      (function() {
        const toggle = document.getElementById('theme-toggle');
        const sun = toggle.querySelector('.theme-icon-sun');
        const moon = toggle.querySelector('.theme-icon-moon');
        function isDark() {
          return document.documentElement.classList.contains('dark') ||
            (!document.documentElement.classList.contains('light') && window.matchMedia('(prefers-color-scheme: dark)').matches);
        }
        function updateIcon() {
          const dark = isDark();
          sun.classList.toggle('theme-icon-hidden', dark);
          moon.classList.toggle('theme-icon-hidden', !dark);
        }
        toggle.addEventListener('click', function() {
          const dark = isDark();
          document.documentElement.classList.remove('light', 'dark');
          document.documentElement.classList.add(dark ? 'light' : 'dark');
          localStorage.setItem('theme', dark ? 'light' : 'dark');
          updateIcon();
        });
        updateIcon();
      })();
    </script>
    <script is:inline>
      (function() {
        const header = document.querySelector('header[data-base-url]');
        const baseUrl = (header && header.getAttribute('data-base-url')) || '/';
        const input = document.getElementById('post-search');
        const resultsEl = document.getElementById('search-results');
        let index = null;

        function getIndex() {
          if (index) return Promise.resolve(index);
          return fetch(baseUrl + 'search-index.json')
            .then(function(r) { return r.ok ? r.json() : []; })
            .then(function(data) { index = data; return index; });
        }

        function showResults(entries) {
          resultsEl.innerHTML = '';
          resultsEl.classList.remove('hidden');
          if (!entries.length) {
            resultsEl.innerHTML = '<div class="px-3 py-2 text-sm text-[var(--color-muted)]">No posts found</div>';
            return;
          }
          entries.slice(0, 8).forEach(function(entry) {
            const a = document.createElement('a');
            a.href = baseUrl + 'blog/' + entry.slug + '/';
            a.className = 'block px-3 py-2 text-sm text-[var(--color-text)] hover:bg-[var(--color-border)] no-underline';
            a.textContent = entry.title;
            a.setAttribute('role', 'option');
            resultsEl.appendChild(a);
          });
        }

        function hideResults() {
          resultsEl.classList.add('hidden');
          resultsEl.innerHTML = '';
        }

        function runSearch(q) {
          const qq = (q || '').trim().toLowerCase();
          if (!qq) { hideResults(); return; }
          getIndex().then(function(entries) {
            const filtered = entries.filter(function(e) {
              const inTitle = e.title && e.title.toLowerCase().includes(qq);
              const inDesc = e.description && e.description.toLowerCase().includes(qq);
              return inTitle || inDesc;
            });
            showResults(filtered);
          });
        }

        input.addEventListener('input', function() { runSearch(this.value); });
        input.addEventListener('focus', function() { if (this.value.trim()) runSearch(this.value); });
        input.addEventListener('keydown', function(e) {
          if (e.key === 'Escape') { this.blur(); hideResults(); }
        });

        document.addEventListener('click', function(e) {
          if (!input.contains(e.target) && !resultsEl.contains(e.target)) hideResults();
        });
      })();
    </script>
    <main class="mx-auto max-w-6xl px-4 py-10 sm:px-6">
      <slot />
    </main>
    <footer class="mt-16 border-t border-[var(--color-border)] bg-[var(--color-bg)] py-8">
      <div class="mx-auto max-w-6xl px-4 text-center text-sm text-[var(--color-muted)]">
        <p>© {new Date().getFullYear()} pixelperson</p>
      </div>
    </footer>
  </body>
</html>
