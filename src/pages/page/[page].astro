---
import Base from "../../layouts/Base.astro";
import { Image } from "astro:assets";
import { getSortedPosts, PAGE_SIZE } from "../../lib/blog";
import YearFilter from "../../components/YearFilter.astro";
import Pagination from "../../components/Pagination.astro";

export async function getStaticPaths() {
  const allPosts = await getSortedPosts();
  const totalPages = Math.ceil(allPosts.length / PAGE_SIZE);
  return Array.from({ length: Math.max(0, totalPages - 1) }, (_, i) => {
    const currentPage = i + 2; // page 2, 3, ...
    const start = (currentPage - 1) * PAGE_SIZE;
    return {
      params: { page: String(currentPage) },
      props: {
        posts: allPosts.slice(start, start + PAGE_SIZE),
        currentPage,
        totalPages,
        years: [...new Set(allPosts.map((p) => p.data.pubDate.getFullYear()))].sort((a, b) => b - a),
      },
    };
  });
}

const { posts, currentPage, totalPages, years } = Astro.props;

function formatDate(date: Date) {
  return date.toLocaleDateString("en-US", {
    year: "numeric",
    month: "short",
    day: "numeric",
  });
}

const baseUrl = import.meta.env.BASE_URL;
---
<Base title={`Pixelperson — Page ${currentPage}`} description="A simple masonry blog">
  <h1 class="mb-4 text-2xl font-bold text-[var(--color-text)]">Posts</h1>
  <YearFilter baseUrl={baseUrl} years={years} currentYear={null} />
  <div class="masonry" id="posts-masonry">
    {posts.map((entry) => {
      const year = entry.data.pubDate.getFullYear();
      return (
        <article class="masonry-item" data-year={year}>
          <a href={`${baseUrl}blog/${entry.slug}/`} class="masonry-card">
            <div class="masonry-card-image-wrap">
              {entry.data.image ? (
                <Image
                  src={entry.data.image}
                  alt={entry.data.title}
                  width={entry.data.image.width}
                  height={entry.data.image.height}
                  format="webp"
                  quality={82}
                  widths={[320, 480, 640, 828, 1080]}
                  sizes="(max-width: 640px) 100vw, (max-width: 1024px) 50vw, 25vw"
                  loading="lazy"
                  class="h-full w-full object-cover"
                />
              ) : (
                <div class="masonry-card-placeholder" aria-hidden="true">
                  {entry.data.title?.slice(0, 1) ?? "?"}
                </div>
              )}
            </div>
            <div class="masonry-card-body">
              <p class="masonry-card-date">{formatDate(entry.data.pubDate)}</p>
              <h2 class="masonry-card-title">{entry.data.title}</h2>
              {entry.data.description && (
                <p class="masonry-card-excerpt">{entry.data.description}</p>
              )}
            </div>
          </a>
        </article>
      );
    })}
  </div>
  <Pagination baseUrl={baseUrl} currentPage={currentPage} totalPages={totalPages} />
</Base>
